# Copy this file to .env and fill in your credentials. The local copy
# is gitignored — never commit real keys.

# ==== LiteLLM proxy (recommended) ====
LITELLM_API_BASE=https://your-litellm-proxy/v1
LITELLM_MASTER_KEY=sk-...

# ==== Optional direct provider keys ====
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=...
# TOGETHER_API_KEY=...
# DEEPSEEK_API_KEY=...
# FIREWORKS_API_KEY=...

# ==== Optional tesslate-agent runtime knobs ====
# TESSLATE_LOG_LEVEL=debug
# TESSLATE_AGENT_WORKDIR=/app
